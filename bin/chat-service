#!/usr/bin/env python3
"""Convenience CLI: manage the pychat client background service.

Thin wrapper around ``python -m chat.client.service`` so the systemd unit
and interactive use can both say ``chat-service <command>``.

Usage:
    bin/chat-service start|stop|restart|status|attach
"""

from __future__ import annotations

import sys
from pathlib import Path

# Allow running this script directly from a checkout without installing the
# package: add the repo root (parent of chat/) to sys.path.
sys.path.insert(0, str(Path(__file__).resolve().parent.parent))

from chat.client.service import main  # noqa: E402

if __name__ == "__main__":
    main()
